# -------------------------------------------------------------------
# Kaizen Redmine MCP Server — environment configuration
# Copy this file to .env and fill in the required values.
# -------------------------------------------------------------------

# [REQUIRED] Base URL of your Redmine instance (no trailing slash)
REDMINE_URL=https://proyectos.kaizen2b.net

# [REQUIRED] API key for the Redmine bot user
REDMINE_API_KEY=your_api_key_here

# [optional] Bind address inside the container (default: 0.0.0.0)
SERVER_HOST=0.0.0.0

# [optional] Port the server listens on (default: 8000)
SERVER_PORT=8000

# [optional] Set to false only when using self-signed TLS certificates (default: true)
REDMINE_SSL_VERIFY=true

# [optional] HTTP request timeout in seconds (default: 30)
HTTP_TIMEOUT=30

# [optional] When true, write tools return an error without touching Redmine (default: false)
REDMINE_MCP_READ_ONLY=false

# [optional] Log verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
